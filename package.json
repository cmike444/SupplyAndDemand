    "type": "git",
    "url": "https://github.com/cmike444/SupplyAndDemand.git"
  },
  "private": false,
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "typescript": "^5.0.0",
    "yahoo-finance2": "^3.14.0"
  }
}
